  "id": "world_7565692c4a4c4ee6b24ee6d53b351fae",
  "version": "0.1.0",
  "created_at": "2026-05-04T03:53:40.499785Z",
  "source": "llm",
  "name": "雨镇旧宅",
  "tagline": "每一滴雨水都藏着不能说的秘密，每一扇木门后都锁着未散的回响。",
  "genre": "中式怪谈调查",
  "era": "1990年代末",
  "tone": [
    "潮湿",
    "悬疑",
    "压抑"
  ],
  "public_rules": [
    "世界观：故事发生在一座与世隔绝的江南古镇，名为‘梅雨镇’。镇子被常年不散的湿气与连绵阴雨笼罩，镇民对某些旧事讳莫如深。",
    "异常现象：玩家在调查过程中可能遭遇‘回响’——由强烈执念或重大创伤在特定地点形成的重复性幻象、声音或气味。回响可以被观察、触碰甚至交互，但每次接触都会增加‘湿意值’（san值替代）。",
    "湿意值：角色初始为0，最高10。每遭遇一次真实回响或极端潮湿事件，湿意值+1。达到5时角色开始出现轻微幻觉与身体不适；达到8时可能被回响‘同化’，需进行意志检定；达到10角色永久消失于雨幕中。",
    "调查机制：核心是‘线索链’。玩家需收集特定地点、物品、证言三类线索，每形成一条完整链能解锁一个‘真相碎片’。三个碎片即可拼出主线谜底。",
    "行动消耗：每个主要行动（如深入搜索、与可疑人物交谈、进入危险区域）会消耗‘干燥值’（初始满格6格）。可用干燥值抵消湿意值增长，或用特殊道具恢复。"
  ],
  "hidden_rules": [
    "回响的触发规则：每个地点的回响有‘触发条件’，例如特定时间、特定话语、某件物品在场。若玩家无意触发了条件，回响强度加倍。",
    "‘镇中老人’实际上是一个活着的‘守回人’组织——他们负责维护回响的平衡，必要时会主动引导或镇压玩家。",
    "主线谜底：三十年前一场灭门惨案的真凶并非人类，而是古宅地基里封印的一股‘水煞’。水煞需要每年吸食一次新鲜执念才能维持平衡，否则整个镇子会被洪水淹没。失踪案正是水煞挑选祭品的过程。",
    "若玩家湿意值≥7且接触了水煞本体，可获得‘半潮之眼’状态：能看见所有回响的过去，但每看一次湿意值+2。"
  ],
  "factions": [
    "守回人",
    "雨声茶馆",
    "旧宅遗属"
  ],
  "common_locations": [
    "陈家老宅",
    "石拱桥",
    "镇卫生院",
    "染坊遗址"
  ],
  "taboos": [
    "不能在午夜后对着枯井喊出任何名字。",
    "不能把染坊遗址的蓝绿色液体直接接触到皮肤。",
    "不能向守回人透露自己看见了‘不该看见的东西’——他们会用‘收惊’的名义强行清除你的记忆。",
    "不能在桥洞下点燃蜡烛或拍照。",
    "不能携带已故亲人的遗物进入老宅。"
  ],
  "recommended_roles": [
    "民俗调查员",
    "镇外记者",
    "神婆弟子"
  ],
  "narration_style": {
    "horror_level": "medium",
    "dialogue_style": "多用方言口语化描写，镇民说话带‘嗲’尾音，老人说话缓慢带有喘息，主角对话采用现代普通话但可以夹杂少量南方词汇。",
    "pacing": "调查阶段偏慢（细节描写湿气、霉味、滴水声），核心回响出现时节奏骤紧（快速切换场景、短句、拟声词），真相揭示时回归压抑但平缓的叙述。"
  },
