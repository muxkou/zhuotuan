{
  "id": "quickstart_rainy_town",
  "version": "1.0",
  "created_at": "2026-05-04T02:31:30.220875Z",
  "source": "llm",
  "name": "雨镇疑云",
  "tagline": "暴雨中的古镇，隐藏着雨水的秘密",
  "genre": "中式怪谈调查",
  "era": "现代（但保留传统风貌）",
  "tone": [
    "潮湿",
    "悬疑",
    "压抑"
  ],
  "public_rules": [
    "暴雨季节，古镇的河流水位上涨，部分道路会被淹没",
    "夜晚能见度极低，雨中容易迷失方向",
    "镇民对某些地点讳莫如深，调查时可能遇到阻挠",
    "失踪案与百年旧宅的传闻有关，线索会随时间或天气变化而消失或显现"
  ],
  "hidden_rules": [
    "雨水能暂时压制某些超自然气息，但也会激活古老的契约",
    "每隔九年一次的大雨之夜，旧宅中的‘那位’会苏醒",
    "玩家若在雨中长时间停留，可能被‘它’盯上",
    "当地某个家族后裔的血可以提供保护或触发陷阱"
  ],
  "factions": [
    "周氏宗族",
    "镇公所",
    "雨中客"
  ],
  "common_locations": [
    "青石板主街（两侧是茶馆、杂货铺）",
    "周氏旧宅（三层砖木结构，后院有枯井）",
    "渡口码头（废弃的乌篷船）",
    "雨神庙（半坍塌，供奉不知名神像）",
    "镇档案馆（潮湿发霉，档案散乱）"
  ],
  "taboos": [
    "子夜时分独自前往旧宅后院",
    "在雨中直接触碰旧宅门环",
    "对镇民提及‘雨夜新娘’的传说",
    "擅自打开旧宅地下室的铁门"
  ],
  "recommended_roles": [
    "记者（具有调查与社交能力）",
    "退伍老兵（擅长野外生存与战斗，尽管战斗少）",
    "民俗学者（能解读古老符号与地方习俗）"
  ],
  "narration_style": {
    "horror_level": "medium",
    "dialogue_style": "含蓄、方言点缀、留白，NPC说话多含潜台词",
    "pacing": "缓慢推进，注重环境描写与心理压迫，关键线索在雨停后突然出现"
  },
